# Django core
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database toggle
# True = local sqlite, False = PostgreSQL using DB_* vars below
USE_SQLITE=True

# Optional: full Neon/Postgres URL (overrides USE_SQLITE and DB_* fields when set)
# Example: postgresql://user:password@host/dbname?sslmode=require
NEON_DATABASE_URL=

# PostgreSQL (used when USE_SQLITE=False)
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=replace-db-password
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=require
DB_CONNECT_TIMEOUT=5
DB_CONN_MAX_AGE=600

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# Security flags (set to True in production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Optional dev perf toggle (DO NOT use in production)
FAST_DEV_HASHER=False

# Integrations
GROQ_API_KEY=
FRONTEND_URL=

# Frontend
VITE_API_URL=http://localhost:8001/api/v1/
